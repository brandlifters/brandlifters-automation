# ─── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with repo + workflow scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username or org where demo repos will live
GITHUB_OWNER=your-github-username

# ─── Vercel ────────────────────────────────────────────────────────────────────
# Vercel API token (Settings > Tokens in your Vercel dashboard)
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Vercel Team ID — leave blank if using a personal account
VERCEL_TEAM_ID=

# ─── Framer ────────────────────────────────────────────────────────────────────
# Framer Server API key (generate in your Framer project settings)
FRAMER_API_KEY=xxxxxxxxxxxxxxxxxxxx

# The CMS Collection ID in Framer where portfolio items live
FRAMER_COLLECTION_ID=xxxxxxxxxxxxxxxxxxxx

# ─── Webhook ───────────────────────────────────────────────────────────────────
# A secret string you set in Vercel dashboard when creating the webhook
# Used to verify that incoming webhook requests are genuinely from Vercel
WEBHOOK_SECRET=your-webhook-secret-here

# Port the local/hosted webhook server listens on
PORT=3000

# ─── Screenshot ────────────────────────────────────────────────────────────────
# Where generated screenshots and thumbnails are saved locally
SCREENSHOT_OUTPUT_DIR=./output/screenshots
THUMBNAIL_OUTPUT_DIR=./output/thumbnails
