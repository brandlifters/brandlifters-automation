{
  "name": "brandlifters-automation",
  "version": "1.0.0",
  "description": "Automation pipeline for publishing BrandLifters demo websites",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "start": "node dist/api/server.js",
    "publish-demo": "ts-node src/scripts/publish-demo.ts",
    "configure-repo": "ts-node src/scripts/configure-repo.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "form-data": "^4.0.0",
    "playwright": "^1.42.1",
    "sharp": "^0.33.3",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.5.0",
    "@types/node": "^20.11.30",
    "@types/sharp": "^0.31.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
